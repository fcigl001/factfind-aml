# PIERS Fact Finder v2 — Environment Configuration
# Copy to .env.local for development, .env.production for build

# ── API ────────────────────────────────────────────────────────────────────────
VITE_API_URL=https://factfindAML.pierstech.com
VITE_API_TIMEOUT=30000

# ── Feature flags ──────────────────────────────────────────────────────────────
VITE_ENABLE_AML=true
VITE_ENABLE_GOOGLE_MAPS=false

# ── Auto-save interval (ms) ────────────────────────────────────────────────────
VITE_AUTO_SAVE_INTERVAL=30000

# ── Notification polling (ms) ─────────────────────────────────────────────────
VITE_NOTIFICATION_POLL_INTERVAL=30000
